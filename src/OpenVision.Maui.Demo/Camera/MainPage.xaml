<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OpenVision.ML.Maui.Demo.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:openVision="http://openVision/winfx/2021/xaml/presentation">

    <Grid ColumnSpacing="0" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="120" />
        </Grid.RowDefinitions>
        <Picker
            x:Name="Models"
            Grid.Row="0"
            Margin="5,5,5,5"
            HorizontalTextAlignment="Center" />
        <Picker
            x:Name="ExecutionProviderOptions"
            Grid.Row="1"
            Margin="5,0,5,5"
            HorizontalTextAlignment="Center" />
        <openVision:Camera
            x:Name="Camera"
            Grid.Row="2"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand" />
        <AbsoluteLayout
            x:Name="WebCamStackLayout"
            Grid.Row="2"
            WidthRequest="{Binding Source={x:Reference Camera}, Path=Width}" />
        <Label
            x:Name="Caption"
            Grid.Row="3"
            Margin="0,20,0,0"
            HorizontalOptions="StartAndExpand"
            VerticalOptions="StartAndExpand"
            VerticalTextAlignment="Start" />
    </Grid>

</ContentPage>
