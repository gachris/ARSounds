<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OpenVision.Maui.Demo.ARCamera.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:openVision="http://openVision/winfx/2021/xaml/presentation">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <openVision:ARCamera
            x:Name="Camera"
            Grid.Row="0"
            HorizontalOptions="FillAndExpand"
            IsTrackingEnabled="True"
            Loaded="Camera_Loaded"
            VerticalOptions="FillAndExpand" />
        <StackLayout
            Grid.Row="1"
            Margin="0,6,0,6"
            HorizontalOptions="CenterAndExpand"
            Orientation="Horizontal"
            Spacing="2">
            <Button Clicked="Image_Reco_Button_Click" Text="Image Reco" />
            <Button Clicked="Db_Reco_Button_Click" Text="Db Reco" />
            <Button Clicked="Cloud_Reco_Button_Click" Text="Cloud Reco" />
        </StackLayout>
    </Grid>

</ContentPage>
