<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ARSounds.UI.Targets.Views.TargetDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:ARSounds.MauiApp.Controls"
    xmlns:fontIcons="clr-namespace:ARSounds.UI.FontIcons"
    xmlns:loc="clr-namespace:ARSounds.UI.Localization"
    xmlns:viewModels="clr-namespace:ARSounds.UI.Targets.ViewModels"
    Title="{loc:LocalizationResource PageTitleProductDetail}"
    x:DataType="{x:Type viewModels:TargetDetailsViewModel}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Frame">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid>
        <ScrollView>
            <StackLayout IsClippedToBounds="True">
                <!--  PRODUCT GALLERY  -->
                <VerticalStackLayout>
                    <Border
                        Margin="-2"
                        Stroke="{StaticResource DefaultBorder}"
                        StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow Opacity="0.1" />
                        </Border.Shadow>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0,0,46,46" />
                        </Border.StrokeShape>

                        <CarouselView
                            HeightRequest="{OnIdiom Phone=400,
                                                    Tablet=500,
                                                    Desktop=600}"
                            IndicatorView="IndicatorView"
                            ItemsSource="{Binding ProductDetail.ImageUrls}">
                            <CarouselView.ItemsLayout>
                                <LinearItemsLayout
                                    Orientation="Horizontal"
                                    SnapPointsAlignment="Center"
                                    SnapPointsType="MandatorySingle" />
                            </CarouselView.ItemsLayout>
                            <CarouselView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Image
                                        Aspect="AspectFill"
                                        HeightRequest="480"
                                        Source="{Binding .}" />
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>
                    </Border>


                    <IndicatorView
                        x:Name="IndicatorView"
                        Margin="0,10,0,10"
                        HorizontalOptions="Center"
                        IndicatorColor="{StaticResource BaseLightTextColor}"
                        IndicatorsShape="Circle"
                        SelectedIndicatorColor="{DynamicResource PrimaryColor}"
                        VerticalOptions="End">
                        <IndicatorView.IndicatorTemplate>
                            <DataTemplate>
                                <Border HeightRequest="10" Style="{StaticResource IndicatorViewStyle}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="30" />
                                    </Border.StrokeShape>
                                </Border>
                            </DataTemplate>
                        </IndicatorView.IndicatorTemplate>
                    </IndicatorView>
                </VerticalStackLayout>

                <StackLayout Margin="20,16">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                        <Label
                            FontSize="15"
                            HorizontalOptions="Start"
                            Text="{Binding ProductDetail.BrandName}"
                            TextColor="{DynamicResource BaseTextColor}"
                            VerticalOptions="Center" />

                        <Label
                            Grid.Column="1"
                            FontFamily="IonIcons"
                            FontSize="25"
                            HorizontalOptions="Center"
                            Text="{x:Static fontIcons:IonIcons.AndroidFavorite}"
                            TextColor="{Binding FavStatusColor}"
                            VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TapFavCommand}" CommandParameter="{Binding FavStatusColor}" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label
                            Grid.Column="2"
                            FontFamily="MaterialDesign"
                            FontSize="25"
                            HorizontalOptions="Center"
                            Text="{x:Static fontIcons:MaterialDesignIcons.Share}"
                            TextColor="{DynamicResource BaseIconColor}"
                            VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    <Label
                        FontSize="20"
                        HorizontalOptions="StartAndExpand"
                        Style="{StaticResource Title1}"
                        Text="{Binding ProductDetail.Name}"
                        VerticalTextAlignment="Center" />

                    <!--  SIZE AND COLOR OPTIONS  -->
                    <StackLayout
                        Margin="0,16"
                        HorizontalOptions="FillAndExpand"
                        Spacing="5">
                        <Label
                            FontSize="15"
                            HorizontalOptions="Start"
                            Text="{loc:LocalizationResource LabelSelectSize}"
                            TextColor="{DynamicResource BaseTextColor}" />

                        <CollectionView ItemsSource="{Binding ProductDetail.Sizes}" SelectionMode="Single">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="10" Orientation="Horizontal" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame
                                        Padding="15,5"
                                        BackgroundColor="{StaticResource BlurBlue}"
                                        BorderColor="Transparent"
                                        CornerRadius="8">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            HorizontalOptions="Center"
                                            Text="{Binding .}"
                                            TextColor="{DynamicResource BaseTextColor}"
                                            VerticalTextAlignment="Center" />
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label
                            Margin="0,10,0,0"
                            FontSize="15"
                            HorizontalOptions="StartAndExpand"
                            Text="{loc:LocalizationResource LabelSelectColor}"
                            TextColor="{DynamicResource BaseTextColor}"
                            VerticalTextAlignment="Center" />
                        <StackLayout
                            BindableLayout.ItemsSource="{Binding ProductDetail.ColorLists}"
                            Orientation="Horizontal"
                            VerticalOptions="Start">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="10,5"
                                        Padding="0"
                                        BackgroundColor="{Binding .}"
                                        HeightRequest="26"
                                        HorizontalOptions="Start"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="1"
                                        WidthRequest="26" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>

                        </StackLayout>
                    </StackLayout>

                    <StackLayout>

                        <Label
                            FontSize="18"
                            HorizontalOptions="StartAndExpand"
                            Text="{loc:LocalizationResource LabelDetails}"
                            VerticalTextAlignment="Center" />

                        <Label
                            FontSize="14"
                            HorizontalOptions="StartAndExpand"
                            Text="{Binding ProductDetail.Details}"
                            VerticalTextAlignment="Center" />

                        <!--<Button
                            Margin="0,20,0,0"
                            BackgroundColor="{DynamicResource PrimaryColor}"
                            CornerRadius="14"
                            HeightRequest="50"
                            Text="ADD TO CART" />-->

                        <Label
                            Margin="0,30,0,0"
                            FontSize="18"
                            HorizontalOptions="StartAndExpand"
                            Text="{loc:LocalizationResource LabelReviews}"
                            VerticalTextAlignment="Center" />

                        <Label
                            Margin="0,5,0,0"
                            FontAttributes="Bold"
                            FontSize="14"
                            HorizontalOptions="StartAndExpand"
                            Text="{loc:LocalizationResource ButtonWriteReview}"
                            TextColor="{DynamicResource PrimaryColor}"
                            VerticalTextAlignment="Center" />
                    </StackLayout>

                    <CollectionView Margin="0,16" ItemsSource="{Binding ProductDetail.Reviews}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="16" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Type viewModels:ReviewModel}">
                                <Frame
                                    Margin="0"
                                    Padding="0"
                                    CornerRadius="20">
                                    <Grid
                                        Padding="20"
                                        RowDefinitions="Auto,0.8,*"
                                        RowSpacing="8">
                                        <Grid ColumnDefinitions="46,*,Auto">
                                            <Border
                                                Padding="0"
                                                HeightRequest="46"
                                                StrokeShape="RoundRectangle 20"
                                                StrokeThickness="0"
                                                WidthRequest="40">
                                                <Image
                                                    Aspect="AspectFill"
                                                    HeightRequest="40"
                                                    Source="{Binding ImageUrl}"
                                                    WidthRequest="40" />
                                            </Border>

                                            <StackLayout
                                                Grid.Column="1"
                                                Margin="8,0"
                                                Spacing="2">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="14"
                                                    Text="{Binding Name}" />
                                                <Label
                                                    Style="{StaticResource Footnote}"
                                                    Text="{Binding Date}"
                                                    VerticalTextAlignment="Center" />
                                            </StackLayout>

                                            <!--<StackLayout
                                                HorizontalOptions="EndAndExpand"
                                                Orientation="Horizontal"
                                                Spacing="5">
                                                <Label
                                                    FontFamily="MaterialDesign"
                                                    FontSize="30"
                                                    Text="{x:Static views:MaterialDesignIcons.Star}"
                                                    TextColor="{DynamicResource Orange}" />
                                                <Label
                                                    FontSize="20"
                                                    Text="{Binding Rating, StringFormat='{0:F1}'}"
                                                    TextColor="{DynamicResource Orange}" />
                                            </StackLayout>-->
                                            <controls:Rating
                                                Grid.Column="2"
                                                HorizontalOptions="EndAndExpand"
                                                Max="5"
                                                Scale=".75"
                                                Value="{Binding Rating}" />

                                        </Grid>

                                        <Rectangle
                                            Grid.Row="1"
                                            Margin="-20,0"
                                            Fill="{DynamicResource BaseSeparatorColor}"
                                            HeightRequest="1"
                                            VerticalOptions="Fill" />

                                        <Label
                                            Grid.Row="2"
                                            Margin="0"
                                            FontSize="14"
                                            Text="{Binding Review}"
                                            TextColor="{DynamicResource BaseTextColor}"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </StackLayout>
        </ScrollView>

        <StackLayout
            Margin="15"
            HeightRequest="42"
            HorizontalOptions="FillAndExpand"
            Orientation="Horizontal"
            VerticalOptions="StartAndExpand">
            <!--  Back Button  -->
            <Border
                Padding="5"
                BackgroundColor="{DynamicResource BasePageColor}"
                HeightRequest="40"
                HorizontalOptions="End"
                StrokeThickness="0"
                VerticalOptions="Start"
                WidthRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PopModalCommand}" />
                </Border.GestureRecognizers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Opacity="0.3" />
                </Border.Shadow>
                <Image HorizontalOptions="Center" VerticalOptions="Center">
                    <Image.Source>
                        <FontImageSource
                            FontFamily="IonIcons"
                            Glyph="{x:Static fontIcons:IonIcons.AndroidClose}"
                            Size="25"
                            Color="{DynamicResource BaseIconColor}" />
                    </Image.Source>
                </Image>
            </Border>

        </StackLayout>

        <Border
            Padding="0"
            Background="{DynamicResource BasePageColor}"
            HeightRequest="80"
            HorizontalOptions="FillAndExpand"
            IsVisible="{Binding IsFooterVisible}"
            StrokeShape="RoundRectangle 6,6,0,0"
            StrokeThickness="1"
            VerticalOptions="EndAndExpand">
            <StackLayout Margin="24,0" Orientation="Horizontal">
                <StackLayout Spacing="0" VerticalOptions="CenterAndExpand">
                    <Label
                        HorizontalOptions="Start"
                        Style="{StaticResource Subhead}"
                        Text="{loc:LocalizationResource LabelPrice}" />
                    <Label
                        HorizontalOptions="Center"
                        Style="{StaticResource Title1}"
                        Text="{Binding ProductDetail.Price, StringFormat='{}{0:c}'}"
                        TextColor="{DynamicResource OkColor}" />
                </StackLayout>

                <Button
                    Padding="54,12"
                    CornerRadius="14"
                    HorizontalOptions="EndAndExpand"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Text="{loc:LocalizationResource ButtonAddToCart}"
                    VerticalOptions="CenterAndExpand" />
            </StackLayout>
        </Border>

    </Grid>
</ContentPage>