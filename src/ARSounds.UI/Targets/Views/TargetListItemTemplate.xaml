<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ARSounds.UI.Targets.Views.TargetListItemTemplate"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:ARSounds.UI.Controls"
    xmlns:viewModels="clr-namespace:ARSounds.UI.Targets.ViewModels"
    x:DataType="{x:Type viewModels:TargetViewModel}">
    <Border
        Padding="10,12"
        BackgroundColor="{DynamicResource BasePageColor}"
        HeightRequest="{OnIdiom Phone='90',
                                Tablet='110',
                                Desktop='120'}"
        Stroke="Transparent"
        StrokeShape="{RoundRectangle CornerRadius=20}">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Path=BindingContext.ShowDetailsCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                  CommandParameter="{Binding .}" />
        </Border.GestureRecognizers>
        <Grid ColumnSpacing="10" RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{OnIdiom Phone='70', Tablet='90', Desktop='110'}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!--  Image  -->
            <controls:RoundedCornerImage
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Source="{Binding BackgroundImage}"
                StrokeShape="{RoundRectangle CornerRadius=12}" />
            <!--  CATEGORY  -->
            <Label
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,0,10,0"
                HorizontalOptions="Start"
                Text="{Binding Title}"
                TextColor="{DynamicResource BaseTextColor}"
                VerticalTextAlignment="End" />
            <!--  ITEM COUNT  -->
            <Label
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,0,10,0"
                FontSize="14"
                HorizontalOptions="Start"
                Opacity=".5"
                Text="{Binding ItemCount, StringFormat='{}{0:F0} items'}"
                TextColor="{DynamicResource BaseTextColor}"
                VerticalTextAlignment="Start" />
        </Grid>
    </Border>
</ContentView>
