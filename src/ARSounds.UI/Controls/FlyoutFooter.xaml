<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ARSounds.MauiApp.Controls.FlyoutFooter"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:loc="clr-namespace:ARSounds.UI.Localization">
    <StackLayout Padding="30,10" HorizontalOptions="Start">
        <Label
            FontAttributes="Bold"
            HorizontalOptions="Start"
            Text="{loc:LocalizationResource StringCopyright}"
            TextColor="{DynamicResource BaseIconColor}" />
        <Label
            HorizontalOptions="Start"
            Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{0:MMMM dd, yyyy}'}"
            TextColor="{DynamicResource BaseLightTextColor}" />
    </StackLayout>
</ContentView>
