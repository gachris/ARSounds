<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net9.0-windows</TargetFramework>
		<UseWPF>true</UseWPF>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" />
		<PackageReference Include="DevToolbox.Wpf" />
		<PackageReference Include="Microsoft.ML" />
		<PackageReference Include="Microsoft.ML.OnnxRuntime" />
		<PackageReference Include="Microsoft.ML.ImageAnalytics" />
		<PackageReference Include="Microsoft.ML.OnnxTransformer" />
		<PackageReference Include="Microsoft.Windows.Compatibility" />
		<PackageReference Include="OpenVision.Wpf" />
	</ItemGroup>

	<ItemGroup>
		<None Remove="Assets\device-db.bin" />
		<None Remove="Assets\img1.jpg" />
		<None Remove="Assets\img2.jpg" />
	</ItemGroup>

	<ItemGroup>
	  <Content Include="Assets\OnnxModels\tinyyolov2-8.onnx">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>

	<ItemGroup>
	  <Resource Include="Assets\device-db.bin">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Resource>
	  <Resource Include="Assets\img1.jpg">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Resource>
	  <Resource Include="Assets\img2.jpg">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Resource>
	</ItemGroup>
	
</Project>
