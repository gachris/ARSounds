<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:devtoolbox="http://devtoolbox.wpf/winfx/2021/xaml/presentation">

    <DataTemplate x:Key="ImageRecoViewTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button
                x:Name="LoadImageButton"
                Grid.Row="0"
                Margin="5"
                Padding="4"
                devtoolbox:UIElementHelper.CornerRadius="2"
                Command="{Binding Load_Image_Button_ClickCommand}"
                Content="Load Image" />
            <ListBox
                x:Name="ImagePreviewListBox"
                Grid.Row="1"
                Margin="5"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding LoadedImages}"
                VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Image
                            Width="100"
                            Height="100"
                            Margin="5"
                            Source="{Binding}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
