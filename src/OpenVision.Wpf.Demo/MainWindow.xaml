<devtoolbox:WindowEx
    x:Class="OpenVision.Wpf.Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devtoolbox="http://devtoolbox.wpf/winfx/2021/xaml/presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Image Recognition App"
    Width="800"
    Height="450"
    mc:Ignorable="d">

    <Grid>
        <!--  Background and layout adjustment  -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Main Content Area  -->
        <StackPanel
            Grid.Row="0"
            Margin="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <!--  First Button: Image Recognition  -->
            <Button
                Width="400"
                Height="60"
                Margin="10"
                devtoolbox:UIElementHelper.CornerRadius="2"
                Click="Image_Reco_Button_Click"
                Content="Match Image using Image Recognition (AR)"
                FontSize="16"
                FontWeight="Bold" />

            <!--  Second Button: Cloud-based ML Image Classification  -->
            <Button
                Width="400"
                Height="60"
                Margin="10"
                devtoolbox:UIElementHelper.CornerRadius="2"
                Click="Image_Classification_Button_Click"
                Content="Image Classification using ML and ONNX"
                FontSize="16"
                FontWeight="Bold" />
        </StackPanel>

        <!--  Footer Section  -->
        <TextBlock
            Grid.Row="1"
            Margin="20"
            HorizontalAlignment="Center"
            FontSize="14"
            FontStyle="Italic"
            Foreground="Gray"
            Text="Powered by Vision.Wpf Demo" />
    </Grid>
</devtoolbox:WindowEx>
