<devtoolbox:WindowEx
    x:Class="OpenVision.Wpf.Demo.ML.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devtoolbox="http://devtoolbox.wpf/winfx/2021/xaml/presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:openVision="http://openVision/winfx/2021/xaml/presentation"
    Title="ML.NET Object Detection (Onnx)"
    Width="640"
    Height="506"
    mc:Ignorable="d">
    <Grid Background="Black">
        <openVision:Camera x:Name="Camera" />
        <Canvas x:Name="WebCamCanvas" Width="{Binding Path=ActualWidth, ElementName=WebCamImage}" />
    </Grid>
</devtoolbox:WindowEx>
