<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ARSounds.UI.WinUI.Camera.Views.ARCameraView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ARSounds.UI.WinUI.Camera.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:openVision="using:OpenVision.WinUI.Controls"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" MinWidth="300" />
        </Grid.ColumnDefinitions>
        <openVision:ARCamera
            x:Name="Camera"
            Grid.Column="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderThickness="1"
            Loaded="Camera_Loaded"
            TrackFound="Camera_TrackFound"
            TrackLost="Camera_TrackLost" />
        <Grid Grid.Column="1" Margin="5,0,5,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock Text="Target ID:" />
                <TextBlock x:Name="TargetIdElement" />
            </StackPanel>
            <Button
                x:Name="StartRecoButton"
                Grid.Row="1"
                Margin="5"
                Padding="4"
                Click="Reload_Reco_Button_Click"
                Content="Reload Recognition" />
        </Grid>
    </Grid>
</UserControl>
