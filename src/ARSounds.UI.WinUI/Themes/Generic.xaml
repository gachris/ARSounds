<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.UI.Converters">
    <ResourceDictionary.MergedDictionaries>

        <ResourceDictionary Source="/ARSounds.UI.WinUI/Themes/Styles/Brushes.xaml" />
        <ResourceDictionary Source="/ARSounds.UI.WinUI/Themes/Styles/FontSizes.xaml" />
        <ResourceDictionary Source="/ARSounds.UI.WinUI/Themes/Styles/TextBlock.xaml" />
        <ResourceDictionary Source="/ARSounds.UI.WinUI/Themes/Styles/Thickness.xaml" />

    </ResourceDictionary.MergedDictionaries>

    <converters:BoolToVisibilityConverter
        x:Key="BoolToVisibilityConverter"
        FalseValue="Collapsed"
        TrueValue="Visible" />

    <converters:BoolToVisibilityConverter
        x:Key="FlipBoolToVisibilityConverter"
        FalseValue="Visible"
        TrueValue="Collapsed" />

</ResourceDictionary>