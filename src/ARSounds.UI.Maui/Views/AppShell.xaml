<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ARSounds.UI.Maui.Views.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:ARSounds.UI.Maui.Localization"
    xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Converters;assembly=CommunityToolkit.Maui"
    xmlns:ui="clr-namespace:ARSounds.UI.Maui"
    xmlns:viewModels="clr-namespace:ARSounds.UI.Common.ViewModels;assembly=ARSounds.UI.Common"
    xmlns:views="clr-namespace:ARSounds.UI.Maui.Views;assembly=ARSounds.UI.Maui"
    Title="ARSounds"
    FlyoutHeaderBehavior="Fixed">
    <Shell.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </Shell.Resources>
    <Shell.FlyoutHeader>
        <ContentView x:DataType="viewModels:AccountViewModel" BindingContext="{x:Static ui:ViewModelLocator.AccountViewModel}">
            <Grid IsVisible="{Binding IsAuthenticated}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Margin="12,0,0,0"
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="{loc:LocalizationResource Text=Application_title}"
                        VerticalOptions="Center" />
                    <ImageButton
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        Command="{Binding SignOutCommand}">
                        <ImageButton.Source>
                            <FontImageSource
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xF3B1;"
                                Size="16" />
                        </ImageButton.Source>
                    </ImageButton>
                </Grid>
                <StackLayout
                    Grid.Row="1"
                    Margin="12,6,0,0"
                    Orientation="Horizontal"
                    Spacing="16">
                    <Border
                        Padding="0"
                        BackgroundColor="#001E51"
                        HeightRequest="56"
                        HorizontalOptions="Start"
                        StrokeShape="RoundRectangle 40"
                        VerticalOptions="Start"
                        WidthRequest="56">
                        <Label
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="CG"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <StackLayout VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Christos Gkatzos" />
                        <Label
                            FontSize="13"
                            Text="christos.gkatzos@hotmail.com"
                            TextColor="Gray" />
                    </StackLayout>
                </StackLayout>
                <Button
                    Grid.Row="2"
                    BackgroundColor="Transparent"
                    FontSize="12"
                    HorizontalOptions="Start"
                    Text="{loc:LocalizationResource Text=Account_settings}" />
            </Grid>
        </ContentView>
    </Shell.FlyoutHeader>
    <Shell.FlyoutFooter>
        <ContentView x:DataType="viewModels:AccountViewModel" BindingContext="{x:Static ui:ViewModelLocator.AccountViewModel}">
            <Button
                Grid.Column="1"
                Margin="4"
                Command="{Binding SignInCommand}"
                HeightRequest="34"
                IsVisible="{Binding IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}"
                Text="{loc:LocalizationResource Text=Add_account}">
                <Button.ImageSource>
                    <FontImageSource
                        FontFamily="Segoe MDL2 Assets"
                        Glyph="&#xE77B;"
                        Size="16"
                        Color="{DynamicResource White}" />
                </Button.ImageSource>
            </Button>
        </ContentView>
    </Shell.FlyoutFooter>
    <FlyoutItem Title="Camera" Route="Camera">
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="Segoe MDL2 Assets"
                Glyph="&#xE722;"
                Size="24" />
        </FlyoutItem.Icon>
        <ShellContent Title="Camera" ContentTemplate="{DataTemplate views:ARCameraPage}" />
    </FlyoutItem>
    <FlyoutItem Title="Settings" Route="Settings">
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="Segoe MDL2 Assets"
                Glyph="&#xE713;"
                Size="24" />
        </FlyoutItem.Icon>
        <ShellContent Title="Settings" ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>
</Shell>
