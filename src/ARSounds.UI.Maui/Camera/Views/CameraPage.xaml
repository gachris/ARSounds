<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ARSounds.UI.Maui.Camera.Views.CameraPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:ARSounds.UI.Maui.Camera.ViewModels"
    x:DataType="{x:Type viewModels:CameraViewModel}"
    ControlTemplate="{OnIdiom DesktopCameraTemplate,
                              Phone={StaticResource PhoneCameraTemplate},
                              Tablet={StaticResource TabletCameraTemplate},
                              Desktop={StaticResource DesktopCameraTemplate}}"
    Shell.PresentationMode="ModalAnimated">
    <ContentPage.Resources>
        <ResourceDictionary Source="../Templates/CameraTemplates.xaml" />
    </ContentPage.Resources>
</ContentPage>
