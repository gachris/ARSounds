<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ARSounds.UI.Maui.Onboardings.Views.WalkthroughPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:ARSounds.UI.Maui.Localization"
    xmlns:onboardings="clr-namespace:ARSounds.UI.Maui.Onboardings"
    xmlns:viewModels="clr-namespace:ARSounds.UI.Maui.Onboardings.ViewModels"
    x:DataType="{x:Type viewModels:WalkthroughViewModel}"
    BackgroundColor="{DynamicResource BasePageColor}"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="*, Auto">
        <CarouselView
            FlowDirection="LeftToRight"
            IndicatorView="IndicatorView"
            IsSwipeEnabled="False"
            ItemsSource="{Binding Boardings}"
            Position="{Binding Position, Mode=TwoWay}">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout
                    Orientation="Horizontal"
                    SnapPointsAlignment="Center"
                    SnapPointsType="MandatorySingle" />
            </CarouselView.ItemsLayout>
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="{x:Type onboardings:WalkthroughBoarding}">
                    <Grid RowDefinitions="*,Auto">
                        <Image
                            Grid.RowSpan="2"
                            Aspect="AspectFill"
                            Opacity="0.9"
                            Source="{Binding ImagePath}" />
                        <Border
                            Grid.Row="1"
                            Margin="-3"
                            VerticalOptions="End">
                            <Border.Shadow>
                                <Shadow Opacity="0.3" />
                            </Border.Shadow>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30,30,0,0" />
                            </Border.StrokeShape>
                            <StackLayout Margin="30,20" Spacing="15">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="24"
                                    HorizontalOptions="Center"
                                    HorizontalTextAlignment="Center"
                                    Text="{Binding Title}"
                                    VerticalOptions="Center" />
                                <Label
                                    FontSize="16"
                                    HorizontalOptions="CenterAndExpand"
                                    HorizontalTextAlignment="Center"
                                    Text="{Binding Subtitle}" />
                            </StackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>
        <StackLayout Grid.Row="1" Spacing="10">
            <IndicatorView
                x:Name="IndicatorView"
                Margin="0"
                HorizontalOptions="Center"
                IndicatorColor="{DynamicResource BaseLightTextColor}"
                IndicatorsShape="Circle"
                SelectedIndicatorColor="{DynamicResource PrimaryColor}" />
            <!--  Next button  -->
            <Button
                Margin="30,20"
                Command="{Binding NextCommand}"
                CornerRadius="12"
                FontAttributes="Bold"
                HeightRequest="50"
                Style="{StaticResource PrimaryActionButtonStyle}"
                Text="FINISH">
                <Button.Triggers>
                    <DataTrigger
                        Binding="{Binding IsSkipButtonVisible}"
                        TargetType="Button"
                        Value="True">
                        <Setter Property="Text" Value="NEXT" />
                        <!--  Multiple Setter elements are allowed  -->
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </StackLayout>
        <!--  Skip button  -->
        <Button
            Margin="20"
            Padding="10,5"
            BackgroundColor="{DynamicResource BasePageColor}"
            Command="{Binding SkipCommand}"
            FontSize="12"
            HeightRequest="26"
            HorizontalOptions="End"
            IsVisible="{Binding IsSkipButtonVisible, Mode=TwoWay}"
            Text="{loc:LocalizationResource ButtonSkip}"
            TextColor="{DynamicResource BaseTextColor}"
            VerticalOptions="StartAndExpand" />
    </Grid>
</ContentPage>